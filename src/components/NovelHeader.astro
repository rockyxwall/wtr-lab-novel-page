---
export interface Props {
  title: string;
  chineseTitle?: string;
  cover?: string;
  author?: string;
  status?: string;
  views?: string;
  chapters?: number;
  rating?: number;
  readers?: number;
  totalChars?: string;
  tags?: string[];
  genres?: string[];
}
const { title, chineseTitle, cover, author, status, views, chapters, rating, readers, totalChars, tags, genres } = Astro.props;
const coverImage = cover || 'https://via.placeholder.com/160x224?text=No+Cover';
const firstGenre = genres?.[0];
---

<div class="layout-body flex flex-col max-w-7xl container mx-auto font-sans antialiased">
  <div>
    <div data-slot="card" data-size="default" data-variant="default" class="group/card flex flex-col gap-0 bg-card text-sm text-card-foreground has-[>img:first-child]:pt-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl shadow rounded-md ring-1 ring-foreground/20 fix-size fix-edge">
      <div data-slot="card-content" class="flex flex-col gap-0 p-2">
        <div class="flex max-sm:flex-col sm:flex-row sm:gap-3">
          <div class="sm:w-44 sm:shrink-0">
            <div class="image-wrap relative rounded-md aspect-3/4 w-full max-sm:max-w-44 max-sm:mx-auto overflow-hidden">
              <img alt={title} loading="lazy" decoding="async" src={coverImage} class="w-full h-full object-cover" style="position: absolute; height: 100%; width: 100%; inset: 0px; color: transparent;">
            </div>
          </div>
          <div class="flex min-w-0 flex-1 flex-col gap-3">
            <div>
              <h1 class="text-lg sm:text-xl font-bold text-card-foreground leading-tight sm:pr-8" translate="no">{title}</h1>
              <div class="mt-2">
                {status && (
                  <div class={`inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-xs font-medium ${status === 'Ongoing' ? 'bg-[#ecfdf5] text-[#059669] dark:bg-[#052e16] dark:text-[#34d399] border border-emerald-500/20' : status === 'Completed' ? 'bg-[#ecfdf5] text-[#059669] dark:bg-[#052e16] dark:text-[#34d399] border border-emerald-500/20' : 'bg-[#fef9c3] text-[#a16207] dark:bg-[#422006] dark:text-[#facc15] border border-yellow-500/20'}`}>{status}</div>
                )}
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {author && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Author</span>
                  <a class="text-xs font-semibold leading-none no-underline hover:underline" href="#" translate="no">{author}</a>
                </div>
              )}
              {status && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Status</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{status}</span>
                </div>
              )}
              {views && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Views</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{views}</span>
                </div>
              )}
              {chapters !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Chapters</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{chapters}</span>
                </div>
              )}
              {rating !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Rating</span>
                  <span class="text-xs font-semibold leading-none flex items-center gap-1">
                    <svg class="icon inline-flex shrink-0 size-4 text-yellow-500"><use href="#star"></use></svg>
                    <span>{rating.toFixed(1)}</span>
                  </span>
                </div>
              )}
              {readers !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Readers</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{readers.toLocaleString()}</span>
                </div>
              )}
              {totalChars && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Chars</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{totalChars}</span>
                </div>
              )}
            </div>
            <div class="flex flex-col gap-2">
              <div class="flex flex-wrap gap-1 max-sm:flex-nowrap max-sm:overflow-x-auto max-sm:pb-1">
                <div class="flex flex-col gap-1 w-full">
                  <div class="flex gap-1 flex-wrap">
                    <div class="flex items-center justify-center rounded-md border border-border/70 bg-transparent gap-0.5">
                      <button type="button" tabindex="0" data-slot="button" class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*='size-'])]:size-4 border border-primary bg-primary text-primary-foreground hover:bg-primary/90 aria-expanded:bg-primary/90 gap-1 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&amp;_svg:not([class*='size-'])]:size-3.5 h-7">
                        <svg class="icon inline-flex shrink-0 size-6"><use href="#bookmark"></use></svg>
                        <span translate="no">Unread</span>
                      </button>
                      <button type="button" tabindex="0" data-slot="button" class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*='size-'])]:size-4 border border-border/70 bg-transparent text-card-foreground hover:bg-muted/50 hover:text-card-foreground aria-expanded:bg-muted/50 aria-expanded:text-card-foreground gap-1 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&amp;_svg:not([class*='size-'])]:size-3.5 h-7">
                        <svg class="icon inline-flex shrink-0 size-6"><use href="#book-open-variant"></use></svg>
                        <span translate="no">Reading</span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <a role="button" tabindex="0" data-slot="button" translate="no" class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center bg-clip-padding whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*='size-'])]:size-4 border border-primary bg-transparent text-primary hover:bg-primary/10 aria-expanded:bg-primary/10 gap-1.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 relative isolate h-9 rounded-lg font-semibold w-full text-sm text-center px-4" href="#">
                <div class="absolute inset-0 overflow-hidden rounded-[inherit] -z-10">
                  <div class="absolute inset-y-0 left-0 bg-primary/10 transition-all duration-500" style={`width: ${chapters && chapters > 0 ? '57.5682%' : '0%'};`}></div>
                </div>
                {chapters && chapters > 0 && (
                  <span class="absolute -top-2 left-1/2 -translate-x-1/2 text-[10px] font-normal tabular-nums bg-black/50 text-white px-1.5 py-px rounded-sm whitespace-nowrap max-sm:text-[9px] max-sm:px-1 max-sm:py-0.5 max-sm:-top-2 max-sm:px-2" translate="no">464 / {chapters}</span>
                )}
                <span>Continue Reading</span>
              </a>
            </div>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-1 max-sm:flex-nowrap max-sm:overflow-x-auto max-sm:pb-2">
          {genres?.map(genre => (
            <a href="#" class={`inline-flex items-center capitalize text-xs border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors ${genre === firstGenre ? 'border-blue-400/50 text-blue-600 dark:text-blue-400 bg-blue-50/50 dark:bg-blue-950/20 hover:bg-blue-100/70 dark:hover:bg-blue-950/40 font-semibold' : 'border-border/70 text-card-foreground'}`}>{genre}</a>
          ))}
          {tags?.filter(tag => tag !== firstGenre).map(tag => (
            <a href="#" class="inline-flex items-center capitalize text-xs font-medium border rounded py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground px-2">{tag}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>
