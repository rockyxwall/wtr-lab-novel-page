---
export interface Props {
  title: string;
  chineseTitle?: string;
  cover?: string;
  author?: string;
  status?: string;
  views?: string;
  chapters?: number;
  rating?: number;
  readers?: number;
  totalChars?: string;
  tags?: string[];
  genres?: string[];
}
const { title, chineseTitle, cover, author, status, views, chapters, rating, readers, totalChars, tags, genres } = Astro.props;
const coverImage = cover || 'https://via.placeholder.com/160x224?text=No+Cover';
const firstGenre = genres?.[0];
---

<div class="layout-body flex flex-col max-w-7xl container mx-auto font-sans antialiased">
  <div>
    <div data-slot="card" data-size="default" data-variant="default" class="group/card flex flex-col gap-0 bg-card text-sm text-card-foreground has-[>img:first-child]:pt-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl shadow rounded-md ring-1 ring-foreground/20 fix-size fix-edge mb-2 overflow-hidden">
      <div data-slot="card-content" class="p-2">

        <!-- ROW 1: Title + Alert button -->
        <div class="flex items-center justify-between gap-2 mb-3">
          <div class="flex-1 min-w-0">
            <h1 class="text-base sm:text-xl font-bold uppercase tracking-wide leading-tight wrap-break-word" translate="no">{title}</h1>
            {chineseTitle && (
              <p class="text-xs sm:text-sm text-foreground mt-0.5 wrap-break-word">{chineseTitle}</p>
            )}
          </div>
          <div class="shrink-0 flex items-center gap-1">
            <button type="button" class="inline-flex items-center justify-center shrink-0 size-8 h-9 w-9 shrink-0 p-0 border-amber-200 text-amber-600 hover:bg-amber-50 rounded-lg self-start cursor-pointer">
              <svg class="icon inline-flex shrink-0 size-4"><use href="#alert-outline"></use></svg>
            </button>
          </div>
        </div>

        <!-- ROW 2: Cover Image + Metadata + Actions -->
        <div class="flex w-full rounded-lg border bg-card/50 overflow-hidden mb-3">

          <!-- LEFT: Cover image -->
          <div class="shrink-0">
            <div class="image-wrap relative rounded-md h-full w-30 sm:w-40 rounded-none zoom group cursor-pointer">
              <!-- Hover zoom overlay -->
              <div class="absolute inset-0 z-10 flex items-center justify-center bg-black/0 group-hover:bg-black/30 transition-colors duration-200 rounded-md">
                <svg class="icon inline-flex shrink-0 size-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-200 drop-shadow-lg">
                  <use href="#zoom_out"></use>
                </svg>
              </div>
              <!-- Blurred background image -->
              <div class="absolute inset-0 overflow-hidden z-0">
                <img alt="" aria-hidden="true" loading="lazy" class="absolute inset-0 w-full h-full object-cover scale-110 blur-sm opacity-60 pointer-events-none select-none" src={coverImage} />
              </div>
              <!-- Main cover image -->
              <img alt={title} loading="eager" class="w-full h-full object-cover rounded-md" src={coverImage} />
            </div>
          </div>

          <!-- RIGHT: Metadata + Actions column -->
          <div class="flex flex-col gap-2 p-2.5 flex-1 min-w-0">

            <!-- Metadata badges -->
            <div class="flex flex-wrap items-center gap-1.5">
              {status && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Status</span>
                  <div class="flex items-center gap-1">
                    <span class:list={[
                      'w-1.5 h-1.5 rounded-full shrink-0',
                      status === 'Ongoing' ? 'bg-yellow-500' : 'bg-red-500'
                    ]}></span>
                    <span class:list={[
                      'text-xs font-semibold leading-none',
                      status === 'Ongoing' ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400'
                    ]} translate="no">{status}</span>
                  </div>
                </div>
              )}
              {views && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Views</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{views}</span>
                </div>
              )}
              {chapters !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Chapters</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{chapters}</span>
                </div>
              )}
              {rating !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Rating</span>
                  <div class="flex items-center gap-0.5">
                    <span class="text-amber-400 text-xs leading-none">&#9733;</span>
                    <span class="text-xs font-semibold leading-none" translate="no">{rating.toFixed(1)}</span>
                  </div>
                </div>
              )}
              {readers !== undefined && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Readers</span>
                  <span class="text-xs font-semibold leading-none">{readers.toLocaleString()}</span>
                </div>
              )}
              {totalChars && (
                <div class="flex flex-col rounded-lg bg-muted/40 border border-border/50 dark:border-white/15 px-2.5 py-1.5 items-center text-center gap-0.5">
                  <span class="text-[9px] uppercase tracking-wide font-bold leading-none text-foreground/80" translate="no">Chars</span>
                  <span class="text-xs font-semibold leading-none" translate="no">{totalChars}</span>
                </div>
              )}
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col gap-1.5 mt-auto">
              <div class="flex gap-1.5">
                <div class="inline-flex w-full flex-1 h-9 rounded-lg" translate="no">
                  <button type="button" class="inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none border border-border bg-card hover:bg-muted hover:text-foreground gap-1.5 rounded-[min(var(--radius),12px)] px-2.5 text-[0.8rem] w-full h-full" aria-expanded="false">
                    <div class="flex items-center gap-1.5 justify-center w-full">
                      <svg class="icon inline-flex shrink-0 size-6"><use href="#book-open-variant"></use></svg>
                      <span translate="no">Reading</span>
                    </div>
                  </button>
                </div>
              </div>
              <a role="button" translate="no" rel="nofollow" class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center bg-clip-padding whitespace-nowrap transition-all outline-none select-none border border-primary bg-transparent text-primary hover:bg-primary/10 gap-1.5 relative isolate h-9 rounded-lg font-semibold w-full text-sm text-center px-4" href="#">
                <div class="absolute inset-0 overflow-hidden rounded-[inherit] -z-10">
                  <div class="absolute inset-y-0 left-0 bg-primary/10 transition-all duration-500" style={`width: ${chapters && chapters > 0 ? '57.5682%' : '0%'};`}></div>
                </div>
                {chapters && chapters > 0 && (
                  <span class="absolute -top-2 left-1/2 -translate-x-1/2 text-[10px] font-normal tabular-nums bg-black/50 text-white px-1.5 py-px rounded-sm whitespace-nowrap max-sm:text-[9px] max-sm:px-1 max-sm:py-0.5 max-sm:-top-2 max-sm:px-2" translate="no">464 / {chapters}</span>
                )}
                <span>Continue Reading</span>
              </a>
            </div>

          </div>
        </div>

        <!-- ROW 3: Tags row -->
        <div class="flex flex-wrap items-center gap-1 max-sm:flex-nowrap max-sm:overflow-x-auto max-sm:pb-2 scroll-thin">
          {genres?.map(genre => (
            <a href="#" class={`inline-flex items-center capitalize text-xs border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors ${genre === firstGenre ? 'border-blue-400/50 text-blue-600 dark:text-blue-400 bg-blue-50/50 dark:bg-blue-950/20 hover:bg-blue-100/70 dark:hover:bg-blue-950/40 font-semibold' : 'border-border/70 text-card-foreground'}`}>{genre}</a>
          ))}
          {tags?.filter(tag => tag !== firstGenre).map(tag => (
            <a href="#" class="inline-flex items-center capitalize text-xs font-medium border rounded py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground px-2">{tag}</a>
          ))}
        </div>

      </div>
    </div>
  </div>
</div>
