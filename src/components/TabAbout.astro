---
export interface Props {
  details?: {
    titles?: string[];
    author?: string;
    authorPinyin?: string;
    authorUrl?: string;
    status?: string;
    dateAdded?: string;
    requested?: string;
    requestedUrl?: string;
    year?: number;
    origin?: string;
    language?: string;
    totalChapters?: number;
  };
  rankings?: {
    daily?: number;
    weekly?: number;
    monthly?: number;
    new?: number;
    allTime?: number;
    popular?: number;
  };
  genres?: string[];
  tags?: string[];
  patrons?: Array<{ name: string; amount: number; rank?: number }>;
  otherNovels?: Array<{ title: string; url: string; cover?: string }>;
}
const { details, rankings, genres, tags, patrons, otherNovels } = Astro.props;
const displayTags = tags?.filter(t => !genres?.includes(t));
const allRankings = rankings ? [
  rankings.daily !== undefined && { label: 'Daily', value: `#${rankings.daily}` },
  rankings.weekly !== undefined && { label: 'Weekly', value: `#${rankings.weekly}` },
  rankings.monthly !== undefined && { label: 'Monthly', value: `#${rankings.monthly}` },
  rankings.new !== undefined && { label: 'New', value: `#${rankings.new}` },
  rankings.allTime !== undefined && { label: 'All', value: `#${rankings.allTime}` },
  rankings.popular !== undefined && { label: 'Popular', value: `#${rankings.popular}` },
].filter(Boolean) : [];
---


<div data-orientation="horizontal" data-activation-direction="left" aria-labelledby="tab-about" id="panel-about" role="tabpanel" tabindex="0" data-index="0" data-slot="tabs-content" class="flex-1 text-sm outline-none">
  <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
    <span class="flex-1 text-base font-semibold text-card-foreground">Novel Summary</span>
  </div>
  <div class="desc-wrap text-foreground">
    <span class="description">
      <slot />
    </span>
    <div class="flex items-center justify-between mb-2">
      <div class="swap">Show more</div>
    </div>
    <span></span>
  </div>

  <!-- Author's Other Novels -->
  {otherNovels && otherNovels.length > 0 && (
    <div class="mb-3">
      <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
        <span class="flex-1 text-base font-semibold text-card-foreground">Author's Other Novels</span>
      </div>
      <ul class="list-none p-0 m-0 border border-border rounded-lg overflow-hidden">
        {otherNovels.map(novel => (
          <li class="border-b border-border last:border-b-0">
            <a target="_blank" class="flex items-center gap-2 hover:bg-muted/50 p-2 no-underline" href={novel.url}>
              <div class="image-wrap relative rounded-md w-10 h-14 shrink-0 overflow-hidden">
                {novel.cover ? (
                  <img alt={novel.title} loading="lazy" decoding="async" src={novel.cover} class="w-full h-full object-cover" style="position: absolute; height: 100%; width: 100%; inset: 0px; color: transparent;">
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-muted text-[8px] text-muted-foreground">No Cover</div>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-sm font-medium text-card-foreground truncate" translate="no">{novel.title}</div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Details -->
  {details && (
    <div class="mb-3">
      <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
        <span class="flex-1 text-base font-semibold text-card-foreground">Details</span>
      </div>
      <div class="flex gap-1.5 flex-wrap [&>span]:bg-muted/40 [&>span]:border [&>span]:border-border/50 [&>span]:dark:border-white/15 [&>span]:rounded-lg [&>span]:px-2 [&>span]:py-1 [&>span]:text-xs">
        {details.author && (
          <span><span class="font-semibold text-muted-foreground">Author </span><span translate="no">{details.author}</span></span>
        )}
        {details.status && (
          <span><span class="font-semibold text-muted-foreground">Status </span><span>{details.status}</span></span>
        )}
        {details.year && (
          <span><span class="font-semibold text-muted-foreground">Year </span><span>{details.year}</span></span>
        )}
        {details.origin && (
          <span><span class="font-semibold text-muted-foreground">Country </span><span>{details.origin}</span></span>
        )}
        {details.language && (
          <span><span class="font-semibold text-muted-foreground">Language </span><span>{details.language}</span></span>
        )}
        {details.totalChapters && (
          <span><span class="font-semibold text-muted-foreground">Total Chapters </span><span>{details.totalChapters}</span></span>
        )}
      </div>
    </div>
  )}

  <!-- Rankings -->
  {allRankings.length > 0 && (
    <div class="mb-3">
      <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
        <span class="flex-1 text-base font-semibold text-card-foreground">Rankings</span>
      </div>
      <div class="text-[13px] leading-relaxed text-card-foreground">
        <div class="flex gap-1.5 flex-wrap [&>a]:no-underline">
          {allRankings.map(r => r && (
            <a class="bg-muted/40 rounded-lg border border-border/50 dark:border-white/15 px-2.5 py-1.5 block hover:bg-muted/60 transition-colors" href="#">
              <div class="flex items-center gap-1">
                <span class="font-semibold text-xs">{r.value}</span>
                <span class="text-xs text-muted-foreground">{r.label}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Genre & Tags -->
  {(genres && genres.length > 0) || (displayTags && displayTags.length > 0) ? (
    <div class="mb-3">
      <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
        <span class="flex-1 text-base font-semibold text-card-foreground">Genre & Tags</span>
      </div>
      <div class="flex gap-1 flex-wrap">
        {genres?.map(genre => (
          <a href="#" class="inline-flex items-center capitalize text-xs font-medium border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground hover:bg-muted/50 hover:text-card-foreground hover:border-primary/50">{genre}</a>
        ))}
        {displayTags?.map(tag => (
          <a href="#" class="inline-flex items-center capitalize text-xs font-medium border rounded py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground hover:bg-muted/50 hover:text-card-foreground hover:border-primary/50 px-2">{tag}</a>
        ))}
      </div>
    </div>
  ) : null}

  <!-- Novel Patrons -->
  {patrons && patrons.length > 0 && (
    <div class="mb-3">
      <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
        <svg class="icon inline-flex size-[18px] text-ticket-gold shrink-0"><use href="#crown"></use></svg>
        <span class="flex-1 text-base font-semibold text-card-foreground">Novel Patrons</span>
      </div>
      <div>
        <div class="npc-rows border border-border rounded-lg overflow-hidden">
          {patrons.map((p, i) => (
            <div class="npc-row flex items-center gap-2 px-3 py-2 border-b border-border last:border-b-0" class:list={{ 'npc-gold': i === 0, 'npc-silver': i === 1, 'npc-bronze': i === 2 }}>
              <span class="npc-rank font-bold text-sm w-6 text-center" class:list={{ 'text-yellow-500': i === 0, 'text-gray-400': i === 1, 'text-amber-700': i === 2, 'text-muted-foreground': i > 2 }}>{i + 1}</span>
              <span class="flex-1 text-sm text-card-foreground">{p.name}</span>
              <span class="npc-ticket-pill inline-flex items-center gap-1 text-xs font-medium" translate="no">
                <svg class="icon inline-flex shrink-0 size-4 npc-icon"><use href="#ticket" class:list={{ 'svg-ticket': i === 0, 'svg-silver': i === 1 }}></use></svg>
                <span class="npc-amount">{p.amount}</span>
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Details grid (titles/author/dateAdded/requested) -->
  {details && (details.titles?.length || details.author || details.dateAdded || details.requested) && (
    <div class="rounded-lg overflow-hidden border border-border mb-0">
      {details.titles && details.titles.length > 0 && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Titles</span>
          <div class="text-[13px] leading-relaxed wrap-break-word [&_a]:no-underline [&_a]:font-semibold [&_a:hover]:text-primary">
            <ul class="m-0 pl-0 list-none [&_li]:py-px [&_li]:text-[13px]">
              {details.titles.map(t => <li>{t}</li>)}
            </ul>
          </div>
        </div>
      )}
      {details.author && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Author</span>
          <div class="text-[13px] leading-relaxed wrap-break-word [&_a]:no-underline [&_a]:font-semibold [&_a:hover]:text-primary flex flex-col gap-px">
            <a href={details.authorUrl || '#'}>{details.author}</a>
            {details.authorPinyin && <a class="text-xs opacity-65" href={details.authorUrl || '#'}>{details.authorPinyin}</a>}
          </div>
        </div>
      )}
      {details.dateAdded && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Date Added</span>
          <div class="text-[13px] leading-relaxed wrap-break-word [&_a]:no-underline [&_a]:font-semibold [&_a:hover]:text-primary"><span>{details.dateAdded}</span></div>
        </div>
      )}
      {details.requested && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Requested</span>
          <div class="text-[13px] leading-relaxed wrap-break-word [&_a]:no-underline [&_a]:font-semibold [&_a:hover]:text-primary">
            <a target="_blank" rel="noopener noreferrer" class="user-name relative inline-flex items-center gap-1" href={details.requestedUrl || '#'}>{details.requested}</a>
          </div>
        </div>
      )}
    </div>
  )}
</div>
